# Copier vers .env.development.local / .env.production.local

NODE_ENV=development
PORT=8080

# Obligatoires
SECRET_KEY=change-me-long-random
SECRET_KEY_INVITATION=change-me-invitation-random
DATABASE_URL=mongodb://...
ORIGIN=http://localhost:4000
FRONT_END=http://localhost:4000
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=

# Cookies (prod : COOKIE_DOMAIN=.cellulenoire.fr + COOKIE_SAME_SITE=lax)
# Dev cross-origin : laisser COOKIE_SAME_SITE vide → none automatiquement
HTTP_ONLY=true
COOKIE_SECURE=true
COOKIE_SAME_SITE=
COOKIE_DOMAIN=

EXPIRED_TOKEN=7d
EXPIRED_TOKEN_INVITATION=24h
CREDENTIALS=true

# Stockage PDF : local | s3
STORAGE_DRIVER=local
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
